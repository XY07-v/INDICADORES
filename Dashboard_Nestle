let reporteActual = "prospecciones";

function init() {
    const nav = document.getElementById('navbar');
    Object.keys(DATA).forEach(id => {
        const b = document.createElement('button');
        b.className = 'btn-nav'; b.innerText = DATA[id].label;
        b.style.backgroundColor = DATA[id].color;
        b.onclick = () => { reporteActual = id; updateSelectors(); updateNav(); render(); };
        b.id = 'btn-' + id;
        nav.appendChild(b);
    });
    updateSelectors();
    updateNav();
    render();
}

function updateNav() {
    document.querySelectorAll('.btn-nav').forEach(b => b.classList.remove('active'));
    document.getElementById('btn-' + reporteActual).classList.add('active');
}

// ESTA FUNCIÓN FILTRA LOS SELECTORES PARA QUE NO SALGAN VACÍOS
function updateSelectors() {
    const d = DATA[reporteActual];
    const rSel = document.getElementById('f-reg');
    const aSel = document.getElementById('f-anio');
    const mSel = document.getElementById('f-mes');

    const regAnterior = rSel.value;

    // Obtener regionales únicas para esta pestaña
    const regs = [...new Set(d.asesores.map(x => x.REGIONAL))].sort();
    rSel.innerHTML = '<option value="todos">TODAS</option>' + regs.map(r => `<option value="${r}">${r}</option>`).join('');
    rSel.value = regs.includes(regAnterior) ? regAnterior : "todos";

    // Obtener Años y Meses filtrados por la regional seleccionada
    const dataFiltrada = regAnterior === "todos" ? d.asesores : d.asesores.filter(x => x.REGIONAL === regAnterior);

    const anios = [...new Set(dataFiltrada.map(x => x.AÑO))].sort((a,b)=>b-a);
    aSel.innerHTML = '<option value="todos">TODOS</option>' + anios.map(a => `<option value="${a}">${a}</option>`).join('');

    const meses = [...new Set(dataFiltrada.map(x => x.MES))].sort((a,b)=>a-b);
    mSel.innerHTML = '<option value="todos">TODOS</option>' + meses.map(m => `<option value="${m}">${MAPA_MESES[m] || 'Mes '+m}</option>`).join('');
}

function render() {
    const d = DATA[reporteActual];
    const rVal = document.getElementById('f-reg').value;
    const aVal = document.getElementById('f-anio').value;
    const mVal = document.getElementById('f-mes').value;

    // Calcular avance del mes hoy
    const f=new Date(), y=f.getFullYear(), m=f.getMonth(), day=f.getDate(), u=new Date(y, m+1, 0).getDate();
    let t_d=0, h_d=0; for(let i=1; i<=u; i++) { if(new Date(y, m, i).getDay()!==0) { t_d++; if(i<=day) h_d++; } }
    const avanceHoy = (h_d/t_d)*100;
    document.getElementById('avance-hoy').innerText = avanceHoy.toFixed(1) + "%";

    const filterFn = r => (rVal==="todos" || String(r.REGIONAL)===rVal) && (aVal==="todos" || String(r.AÑO)===aVal) && (mVal==="todos" || String(r.MES)===mVal);

    const process = (list, mCol, rCol) => {
        return list.filter(filterFn)
            .map(r => ({ ...r, _c: (r[rCol]/r[mCol]*100) || 0 }))
            .sort((a,b) => b._c - a._c);
    };

    const row = (r, mC, rC, key) => {
        const s = r._c >= avanceHoy ? '<span class="c-verde">✔</span>' : '<span class="c-rojo">✘</span>';
        return `<tr><td>${r[key]}</td><td>${Math.round(r[mC])}</td><td>${Math.round(r[rC])}</td><td>${r._c.toFixed(1)}%</td><td style="text-align:center">${s}</td></tr>`;
    };

    document.getElementById('body-asesores').innerHTML = process(d.asesores, d.meta_col, d.real_col).map(r => row(r, d.meta_col, d.real_col, 'NOMBRE COMPLETO')).join('');
    document.getElementById('body-regionales').innerHTML = process(d.regionales, d.meta_col, d.real_col).map(r => row(r, d.meta_col, d.real_col, 'REGIONAL')).join('');
}
